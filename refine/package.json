    "live": "node bin/cli.mjs live",
    "relay": "node server/relay.mjs"
  },
  "keywords": [
    "transitions",
    "css",
    "motion",
    "animation",
    "timeline",
    "refine",
    "cursor",
    "agent"
  ],
  "homepage": "https://transitions.dev/",
  "repository": {
    "type": "git",
