  "description": "Live, agent-driven Refine panel for CSS/Motion transitions — injects a timeline + Refine UI and runs transitions.dev suggestions via your coding agent.",
  "type": "module",
  "bin": {
    "refine": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    "server",
    "demo.html",
